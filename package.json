{
  "name": "react-pings",
  "version": "0.0.1",
  "description": "Modern toast notification library for react",
  "repository": "https://github.com/omkashyap28/react-pings",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "start": "tsup && pnpm run tailwindcss --watch",
    "build": "tsup && pnpm run tailwindcss",
    "tailwindcss": "npx @tailwindcss/cli -i ./src/index.css -o ./dist/index.css",
    "test": "jest --runInBand",
    "setup": "pnpm i && cd site && pnpm i && cd .. && pnpm run link",
    "link": "pnpm link ./site/node_modules/react && pnpm link ./site/node_modules/react-dom && pnpm link ./site/node_modules/motion",
    "size": "size-limit",
    "prepare": "husky"
  },
  "husky": {
    "lint-staged": {
      "**/*": "prettier --write --ignore-unknown"
    }
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "5.5 KB"
    },
    {
      "path": "dist/index.cjs",
      "limit": "5.5 KB"
    },
    {
      "path": "dist/index.css",
      "limit": "5.5 KB"
    }
  ],
  "keywords": [
    "react",
    "motion",
    "tailwindcss",
    "toast",
    "typescript"
  ],
  "author": "Hariom Kashyap",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.0.1",
    "@tailwindcss/cli": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "esbuild-minify-templates": "^0.13.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "motion": "^12.38.0",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "size-limit": "^12.0.1",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "goober": "^2.1.18"
  },
  "peerDependencies": {
    "motion": ">=12",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}